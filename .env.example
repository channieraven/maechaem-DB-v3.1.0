# ─────────────────────────────────────────────────────────────────────────────
# Mae Chaem GIS — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your app → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vite exposes vars prefixed with VITE_ to the browser bundle.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Cloudflare account credentials (used by wrangler for D1 operations).
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# D1 database ID — shown in the Cloudflare dashboard after running:
#   wrangler d1 create maechaem-db
# Also set this value in wrangler.json under d1_databases[].database_id
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_id
