# ─────────────────────────────────────────────────────────────────────────────
# Mae Chaem GIS — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your app → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vite exposes vars prefixed with VITE_ to the browser bundle.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Direct Neon connection string — used in all contexts:
#   - Migrations : npm run db:push / npm run db:generate (Drizzle Kit reads .env)
#   - Local dev  : wrangler dev reads .dev.vars (copy this value there too)
#   - Production : set as a Worker secret → wrangler secret put DATABASE_URL
#
# Get it from: https://console.neon.tech → Your project → Connection Details
#   → Connection string (pooled connection OFF for the direct URL)
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Cloudflare account credentials (used by wrangler for deployments).
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
