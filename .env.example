# ─────────────────────────────────────────────────────────────────────────────
# Mae Chaem GIS — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (used locally and for Drizzle migrations).
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your app → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vite exposes vars prefixed with VITE_ to the browser bundle.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudflare (for local wrangler dev only) ───────────────────────────────────
# These are typically set via `wrangler secret put` in production.
# For local Wrangler dev, you can set them here OR in .dev.vars (see below).
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
