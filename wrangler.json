{
  "name": "maechaem-db-rfd",
  "main": "src/worker/index.ts",
  "compatibility_date": "2025-03-01",
  "compatibility_flags": ["nodejs_compat"],

  "build": {
    "command": "npm run build"
  },

  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },

  "vars": {
    "ENVIRONMENT": "production"
  },

  "dev": {
    "port": 8788,
    "local_protocol": "http"
  }
}
