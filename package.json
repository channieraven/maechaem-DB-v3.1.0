{
  "name": "maechaem-gis-dashboard",
  "version": "3.1.0",
  "private": true,
  "type": "module",
  "description": "Interactive Web GIS dashboard for visualizing agroforestry plots in Mae Chaem, Thailand — 100% Cloudflare-native stack",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "cf:dev": "wrangler dev",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/backend": "^1.26.0",
    "@clerk/clerk-js": "^5.67.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.4",
    "svix": "^1.86.0",
    "maplibre-gl": "^5.3.0",
    "postgres": "^3.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250304.0",
    "@types/node": "^22.13.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.9",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.4.1",
    "wrangler": "^4.4.0"
  }
}
